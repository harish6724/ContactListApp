<!DOCTYPE html>
<html lang="en" id="htmlRoot">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ContactList</title>
    <script>
        (function () {
            var t = localStorage.getItem('theme') || 'light';
            document.documentElement.setAttribute('data-bs-theme', t);
        })();
    </script>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
    <nav class="navbar navbar-expand-lg glass-navbar">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Contacts" asp-action="Index">
                <i class="bi bi-person-lines-fill me-2"></i>ContactList
            </a>
            <button class="navbar-toggler border-0" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Contacts" asp-action="Index">
                                <i class="bi bi-people me-1"></i>My Contacts
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Contacts" asp-action="Create">
                                <i class="bi bi-person-plus me-1"></i>Add Contact
                            </a>
                        </li>
                    }
                </ul>
                <div class="d-flex align-items-center gap-2">
                    <button id="darkModeToggle" class="btn btn-glass btn-sm" title="Toggle dark mode">
                        <i id="darkModeIcon" class="bi bi-moon-stars-fill"></i>
                    </button>
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <span class="navbar-text text-white opacity-75 small">
                            <i class="bi bi-person-circle me-1"></i>@User.Identity!.Name
                        </span>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                            <button type="submit" class="btn btn-exit btn-sm">
                                <i class="bi bi-power me-1"></i>Exit
                            </button>
                        </form>
                    }
                    else
                    {
                        <a class="nav-link text-white" asp-controller="Account" asp-action="Login">Login</a>
                        <a class="nav-link text-white" asp-controller="Account" asp-action="Register">Register</a>
                    }
                </div>
            </div>
        </div>
    </nav>

    <main class="container py-4">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show glass-alert" role="alert">
                <i class="bi bi-check-circle me-2"></i>@TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show glass-alert" role="alert">
                <i class="bi bi-exclamation-circle me-2"></i>@TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }
        @RenderBody()
    </main>

    <footer class="footer-glass py-3 mt-4 text-center small">
        &copy; @DateTime.Now.Year ContactList App
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
