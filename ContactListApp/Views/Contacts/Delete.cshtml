@model Contact
@{
    ViewData["Title"] = "Delete Contact";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card border-danger shadow-sm">
            <div class="card-header bg-danger text-white">
                <h5 class="mb-0"><i class="bi bi-exclamation-triangle me-2"></i>Confirm Delete</h5>
            </div>
            <div class="card-body text-center p-4">
                @if (!string.IsNullOrEmpty(Model.PhotoPath))
                {
                    <img src="@Model.PhotoPath" alt="@Model.FullName"
                         class="rounded-circle mb-3 contact-avatar" />
                }

                <h4>@Model.FullName</h4>
                @if (!string.IsNullOrEmpty(Model.Email))
                {
                    <p class="text-muted">@Model.Email</p>
                }

                <p class="text-danger mt-3">
                    <i class="bi bi-exclamation-circle me-1"></i>
                    This will permanently delete this contact and cannot be undone.
                </p>

                <form asp-action="Delete" method="post" class="d-flex gap-2 justify-content-center mt-3">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash me-1"></i>Yes, Delete
                    </button>
                    <a asp-action="Details" asp-route-id="@Model.Id" class="btn btn-outline-secondary">Cancel</a>
                </form>
            </div>
        </div>
    </div>
</div>
