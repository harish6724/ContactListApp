@model IEnumerable<Contact>
@{
    ViewData["Title"] = "My Contacts";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h2><i class="bi bi-people me-2 text-primary"></i>My Contacts</h2>
    <a asp-action="Create" class="btn btn-primary">
        <i class="bi bi-person-plus me-1"></i>Add Contact
    </a>
</div>

<div class="card mb-4">
    <div class="card-body">
        <form method="get" class="row g-2 align-items-end">
            <div class="col-sm-6">
                <label class="form-label fw-semibold">Search</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-search"></i></span>
                    <input type="text" name="search" value="@ViewBag.Search"
                           class="form-control" placeholder="Name, email, phone, city..." />
                </div>
            </div>
            <div class="col-sm-4">
                <label class="form-label fw-semibold">Filter by Tag</label>
                <input type="text" name="tag" value="@ViewBag.Tag"
                       class="form-control" placeholder="e.g. work, family" />
            </div>
            <div class="col-sm-2 d-grid gap-2">
                <button type="submit" class="btn btn-outline-primary">Filter</button>
                @if (!string.IsNullOrEmpty(ViewBag.Search as string) || !string.IsNullOrEmpty(ViewBag.Tag as string))
                {
                    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">Clear</a>
                }
            </div>
        </form>
    </div>
</div>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="bi bi-person-x display-3"></i>
        <p class="mt-3 fs-5">No contacts found.</p>
        @if (string.IsNullOrEmpty(ViewBag.Search as string) && string.IsNullOrEmpty(ViewBag.Tag as string))
        {
            <a asp-action="Create" class="btn btn-primary mt-2">Add your first contact</a>
        }
    </div>
}
else
{
    <p class="text-muted small mb-2">Showing @Model.Count() of @ViewBag.TotalCount contacts</p>
    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-3">
        @foreach (var contact in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm contact-card">
                    <div class="card-body">
                        <div class="d-flex align-items-center mb-3">
                            @if (!string.IsNullOrEmpty(contact.PhotoPath))
                            {
                                <img src="@contact.PhotoPath" alt="@contact.FullName"
                                     class="rounded-circle me-3 contact-avatar" />
                            }
                            else
                            {
                                <div class="contact-avatar-placeholder rounded-circle me-3 d-flex align-items-center justify-content-center bg-primary text-white fs-4">
                                    @contact.FirstName[0]@contact.LastName[0]
                                </div>
                            }
                            <div>
                                <h5 class="card-title mb-0">@contact.FullName</h5>
                                @if (!string.IsNullOrEmpty(contact.City))
                                {
                                    <small class="text-muted"><i class="bi bi-geo-alt me-1"></i>@contact.City@(contact.State != null ? $", {contact.State}" : "")</small>
                                }
                            </div>
                        </div>

                        @if (!string.IsNullOrEmpty(contact.Email))
                        {
                            <p class="mb-1 small">
                                <i class="bi bi-envelope text-secondary me-2"></i>
                                <a href="mailto:@contact.Email">@contact.Email</a>
                            </p>
                        }
                        @if (!string.IsNullOrEmpty(contact.Phone))
                        {
                            <p class="mb-1 small">
                                <i class="bi bi-telephone text-secondary me-2"></i>
                                <a href="tel:@contact.Phone">@contact.Phone</a>
                            </p>
                        }

                        @if (contact.TagList.Any())
                        {
                            <div class="mt-2">
                                @foreach (var tag in contact.TagList)
                                {
                                    <a asp-action="Index" asp-route-tag="@tag"
                                       class="badge bg-secondary text-decoration-none me-1">@tag</a>
                                }
                            </div>
                        }
                    </div>
                    <div class="card-footer bg-transparent d-flex gap-2">
                        <a asp-action="Details" asp-route-id="@contact.Id" class="btn btn-sm btn-outline-primary flex-fill">
                            <i class="bi bi-eye me-1"></i>View
                        </a>
                        <a asp-action="Edit" asp-route-id="@contact.Id" class="btn btn-sm btn-outline-secondary flex-fill">
                            <i class="bi bi-pencil me-1"></i>Edit
                        </a>
                        <a asp-action="Delete" asp-route-id="@contact.Id" class="btn btn-sm btn-outline-danger flex-fill">
                            <i class="bi bi-trash me-1"></i>Delete
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
}
